# SuperGrok Environment Configuration
# Copy to .env and fill in your values
# No Google · No Meta · 127.0.0.1 Only · a-shell / iSH compatible

# Server - UNIFIED PORT ARCHITECTURE
# All services funnel through port 9898 (single entry point)
# If PORT_BRIDGE matches PORT_UNIFIED (default), the proxy listener is skipped automatically.
PORT_UNIFIED=9898
PORT_BRIDGE=9898
PORT_AUTH=9898

# Logging
LOG_DIR=./logs
VERBOSE=0

# TTS — Piper (local binary)
# PIPER_BIN=./piper
# PIPER_MODEL=./en_US-lessac-medium.onnx

# TTS — Coqui (HTTP server, start with: python coqui_tts_service.py --serve)
COQUI_URL=http://localhost:5002

# AI API Keys (set at least one for AI features)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# XAI_API_KEY=xai-...

# Database (if applicable)
# POSTGRES_PASSWORD=
# DATABASE_URL=

# Secret Key (auto-generated if not set)
# SECRET_KEY=
