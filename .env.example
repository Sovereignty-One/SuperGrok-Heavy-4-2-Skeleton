# SuperGrok Environment Configuration
# Copy to .env and fill in your values
# No Google · No Meta · 127.0.0.1 Only · a-shell / iSH compatible

# Server (ports 9898 + 9899 — compatible with a-shell / iSH)
PORT_UNIFIED=9898
PORT_BRIDGE=9899
PORT_AUTH=9899

# Logging
LOG_DIR=./logs
VERBOSE=0

# TTS — Piper (local binary)
# PIPER_BIN=./piper
# PIPER_MODEL=./en_US-lessac-medium.onnx

# TTS — Coqui (HTTP server, start with: python coqui_tts_service.py --serve)
COQUI_URL=http://localhost:5002

# AI API Keys (set at least one for AI features)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# XAI_API_KEY=xai-...

# Database (if applicable)
# POSTGRES_PASSWORD=
# DATABASE_URL=

# Secret Key (auto-generated if not set)
# SECRET_KEY=
