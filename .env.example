# SuperGrok Environment Configuration
# Copy to .env and fill in your values

# Server
PORT_UNIFIED=9000
PORT_BRIDGE=9898
PORT_AUTH=8443

# Logging
LOG_DIR=./logs
VERBOSE=0

# TTS — Piper (local binary)
# PIPER_BIN=./piper
# PIPER_MODEL=./en_US-lessac-medium.onnx

# TTS — Coqui (HTTP server, start with: python coqui_tts_service.py --serve)
COQUI_URL=http://localhost:5002

# AI API Keys (set at least one for AI features)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# XAI_API_KEY=xai-...

# Database (if applicable)
# POSTGRES_PASSWORD=
# DATABASE_URL=

# Secret Key (auto-generated if not set)
# SECRET_KEY=
