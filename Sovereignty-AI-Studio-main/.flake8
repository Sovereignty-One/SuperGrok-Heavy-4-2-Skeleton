[flake8]
max-line-length = 120
extend-ignore = E203,W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    *.egg,
    .eggs,
    venv,
    env,
    node_modules,
    .devcontainer,
    Sovereignty_python-keycloak-master,
    piper-tts,
    resources,
    ai_core,
    src/agents,
    src/core,
    src/security,
    src/models,
    src/utils/Mapping.py,
    src/utils/Reasoning.py,
    src/utils/Remove-word.py,
    src/utils/Verifier.py,
    src/utils/remove-Word.py,
    src/utils/fonttools.py,
    src/utils/sources.py,
    src/utils/validator.py,
    scripts/Secure_Audit.py,
    scripts/fullscan_cli.py,
    scripts/multiAgentOrch.py,
    scripts/reasercgerAgent.py,
    scripts/subAgentorc.py,
    scripts/Build_Judge.py,
    scripts/Backend_API_AUTH.py,
    scripts/eeg_streaming.py,
    ring_gate_boot_nfc_9v.asm,
    frontend
